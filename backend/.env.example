# ==============================================================
# ENVIRONMENT VARIABLES — ThangLong University Web
# ==============================================================
# HƯỚNG DẪN:
#   1. Copy file này thành .env
#   2. Điền giá trị thực vào từng biến
#   3. KHÔNG commit file .env lên git (đã có trong .gitignore)
# ==============================================================

# ---------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------
SERVER_PORT=8080
SPRING_APPLICATION_NAME=ThangLongUniversityWeb
APP_FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------
# DATABASE — PostgreSQL
# ---------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=webtruong
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# JPA / Hibernate
SPRING_JPA_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# ---------------------------------------------------------------
# REDIS
# ---------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# Thời gian sống Refresh Token (ngày)
APP_REDIS_REFRESH_TOKEN_TTL_DAYS=7

# ---------------------------------------------------------------
# KAFKA
# ---------------------------------------------------------------
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=university-group

# ---------------------------------------------------------------
# JWT — JSON Web Token
# ---------------------------------------------------------------
# QUAN TRỌNG: Thay bằng chuỗi random 256-bit Base64
# Tạo bằng: openssl rand -base64 64
APP_JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_64_output_here

# Access Token TTL (ms) — mặc định 15 phút = 900000
APP_JWT_EXPIRATION_MS=900000

# Refresh Token TTL (ms) — mặc định 7 ngày = 604800000
APP_JWT_REFRESH_EXPIRATION_MS=604800000

# ---------------------------------------------------------------
# COOKIE
# ---------------------------------------------------------------
APP_COOKIE_SECURE=false
APP_COOKIE_SAME_SITE=Lax
APP_COOKIE_PATH=/
APP_COOKIE_REFRESH_TOKEN_NAME=refresh_token

# ---------------------------------------------------------------
# VNPAY — Thanh toán học phí
# ---------------------------------------------------------------
VNPAY_TMN_CODE=FMQW52FA
VNPAY_HASH_SECRET=5TO45K0S1P2URJNA3FHMFNYUURLN3NJ5
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/api/payments/vnpay/return
VNPAY_VERSION=2.1.0
VNPAY_COMMAND=pay

# ---------------------------------------------------------------
# CORS — Allowed Origins (phân cách bằng dấu phẩy)
# ---------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,https://thang-long-university-web.vercel.app

# ---------------------------------------------------------------
# DOCKER — PostgreSQL container (dùng trong docker-compose.yml)
# ---------------------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=uni_db

# ---------------------------------------------------------------
# PGADMIN
# ---------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# ---------------------------------------------------------------
# AI CHATBOT (Groq)
# ---------------------------------------------------------------
GROQ_API_KEY=CHANGE_ME_GROQ_API_KEY

# ---------------------------------------------------------------
# CLOUDINARY (Knowledge document uploads)
# ---------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=CHANGE_ME_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=CHANGE_ME_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=CHANGE_ME_CLOUDINARY_API_SECRET

# ---------------------------------------------------------------
# EMBEDDING (Optional - deprecated, RAG uses PostgreSQL full-text search)
# ---------------------------------------------------------------
# HUGGINGFACE_API_KEY=
